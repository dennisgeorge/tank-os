ARG FEDORA_BOOTC_BASE=quay.io/fedora/fedora-bootc:latest
FROM ${FEDORA_BOOTC_BASE}

LABEL containers.bootc=1 \
  org.opencontainers.image.title="tank-os" \
  org.opencontainers.image.description="Fedora bootc image for OpenClaw on rootless Podman" \
  org.opencontainers.image.source="https://github.com/LobsterTrap/tank-os"

ARG OPENCLAW_UID=1000
ARG OPENCLAW_GID=1000
ARG OPENCLAW_SUBID_START=100000
ARG OPENCLAW_SUBID_COUNT=65536

RUN set -eux; \
    dnf -y install \
      cloud-init \
      openssh-server \
      podman \
      python3 \
      shadow-utils \
      sudo \
      vim-enhanced; \
    dnf clean all; \
    rm -rf /var/cache/dnf /var/log/dnf*; \
    getent group openclaw >/dev/null || groupadd -g "${OPENCLAW_GID}" openclaw; \
    id -u openclaw >/dev/null 2>&1 || \
      useradd -u "${OPENCLAW_UID}" -g "${OPENCLAW_GID}" -m -d /var/home/openclaw -s /bin/bash openclaw; \
    usermod -aG wheel openclaw; \
    grep -q '^openclaw:' /etc/subuid 2>/dev/null || \
      printf 'openclaw:%s:%s\n' "${OPENCLAW_SUBID_START}" "${OPENCLAW_SUBID_COUNT}" >> /etc/subuid; \
    grep -q '^openclaw:' /etc/subgid 2>/dev/null || \
      printf 'openclaw:%s:%s\n' "${OPENCLAW_SUBID_START}" "${OPENCLAW_SUBID_COUNT}" >> /etc/subgid; \
    install -d -m 0700 -o openclaw -g openclaw /var/home/openclaw/.openclaw; \
    install -d -m 0755 /var/lib/systemd/linger; \
    touch /var/lib/systemd/linger/openclaw

COPY rootfs/ /

RUN set -eux; \
    chmod 0755 \
      /usr/local/bin/openclaw \
      /usr/local/bin/tank-os-version \
      /usr/local/bin/tank-openclaw-secrets \
      /usr/libexec/tank-os/bootstrap-openclaw \
      /usr/libexec/tank-os/bootstrap-service-gator \
      /usr/libexec/tank-os/sync-podman-secrets; \
    chmod 0440 /etc/sudoers.d/openclaw; \
    chown -R openclaw:openclaw /var/home/openclaw; \
    systemctl enable sshd.service; \
    for unit in \
      cloud-init-local.service \
      cloud-init-network.service \
      cloud-init.service \
      cloud-config.service \
      cloud-final.service \
      cloud-init.target; \
    do \
      if [ -e "/usr/lib/systemd/system/${unit}" ] || [ -e "/etc/systemd/system/${unit}" ]; then \
        systemctl enable "${unit}"; \
      fi; \
    done
